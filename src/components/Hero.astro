---
---

<section id="top" class="section min-h-[90vh] flex items-center justify-center relative pb-0">

  <div class="relative z-10 w-full max-w-2xl mx-auto">
    <div class="terminal reveal">
      <div class="terminal-bar">
        <div class="terminal-dot bg-red-500/80"></div>
        <div class="terminal-dot bg-yellow-500/80"></div>
        <div class="terminal-dot bg-green-500/80"></div>
        <span class="ml-2 text-xs text-slate-500">~/caleb-grant</span>
      </div>
      <div class="terminal-body">
        <div class="terminal-line">
          <span class="terminal-prompt">$</span>
          <span class="text-slate-300"><span class="text-emerald-400">whoami</span></span>
        </div>
        <div class="mt-3 space-y-1">
          <p class="text-white font-display text-2xl md:text-3xl font-bold" id="hero-name">Caleb Grant</p>
          <p class="text-accent-400 min-h-[1.5em]" id="hero-role"></p>
        </div>

        <div class="mt-4 terminal-line">
          <span class="terminal-prompt">$</span>
          <span class="text-slate-300"><span class="text-emerald-400">cat</span> about.txt</span>
        </div>
        <p class="text-slate-400 leading-relaxed mt-1" id="hero-desc">
          Building scalable data pipelines, cloud-native workflows,<br class="hidden md:inline" />
          and interactive web applications.
        </p>

        <div class="mt-4 terminal-line">
          <span class="terminal-prompt">$</span>
          <span id="hero-cmd" class="text-slate-300"></span>
          <span class="terminal-cursor" id="hero-cursor"></span>
        </div>
      </div>
    </div>

    <div class="mt-8 flex items-center justify-center gap-4 reveal reveal-delay-2">
      <a href="#projects" class="btn-primary">
        View Projects
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path d="M19 9l-7 7-7-7" />
        </svg>
      </a>
      <a href="#about" class="group relative inline-flex items-center gap-2 px-5 py-2.5 rounded-lg font-medium text-sm text-slate-300 border border-slate-600 hover:text-white transition-all duration-300 overflow-hidden hover:border-transparent hover:shadow-lg hover:shadow-accent-500/10">
        <span class="absolute inset-0 bg-gradient-to-r from-accent-500/20 to-violet-500/20 opacity-0 group-hover:opacity-100 transition-opacity duration-300 rounded-lg"></span>
        <span class="absolute inset-0 rounded-lg opacity-0 group-hover:opacity-100 transition-opacity duration-300" style="background: linear-gradient(to right, var(--color-accent-400), var(--color-violet-400)); -webkit-mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0); mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0); -webkit-mask-composite: xor; mask-composite: exclude; padding: 1px;"></span>
        <span class="relative">About Me</span>
      </a>
    </div>
  </div>
</section>

<script>
  function initTypewriter() {
    const roles = [
      "Data Engineer",
      "Full-Stack Developer",
      "Geospatial Developer",
      "Data Plumber",
    ];

    const roleEl = document.getElementById("hero-role");
    const cmdEl = document.getElementById("hero-cmd");
    const cursorEl = document.getElementById("hero-cursor");
    if (!roleEl || !cmdEl || !cursorEl) return;

    let roleIndex = 0;
    let charIndex = 0;
    let deleting = false;
    let cmdTyped = false;

    // Type out the initial command
    const command = "ls projects/";
    let cmdCharIndex = 0;

    function typeCmdChar() {
      if (cmdCharIndex <= command.length) {
        cmdEl.innerHTML = `<span class="text-emerald-400">${command.slice(0, 2)}</span>${command.slice(2, cmdCharIndex)}`;
        cmdCharIndex++;
        setTimeout(typeCmdChar, 80 + Math.random() * 60);
      } else {
        cmdTyped = true;
      }
    }

    function typeRole() {
      const current = roles[roleIndex];

      if (!deleting) {
        roleEl.textContent = current.slice(0, charIndex);
        charIndex++;
        if (charIndex > current.length) {
          setTimeout(() => { deleting = true; typeRole(); }, 2000);
          return;
        }
        setTimeout(typeRole, 60 + Math.random() * 40);
      } else {
        charIndex--;
        roleEl.textContent = current.slice(0, charIndex);
        if (charIndex === 0) {
          deleting = false;
          roleIndex = (roleIndex + 1) % roles.length;
          setTimeout(typeRole, 400);
          return;
        }
        setTimeout(typeRole, 30);
      }
    }

    // Start sequences
    setTimeout(typeRole, 600);
    setTimeout(typeCmdChar, 1800);
  }

  initTypewriter();
  document.addEventListener("astro:after-swap", initTypewriter);
</script>
